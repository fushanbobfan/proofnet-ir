{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fushanbobfan/proofnet-ir/schemas/canonical-key-v0.2.schema.json",
  "title": "ProofNet-IR intrinsic exact canonical key v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "canonicalization",
    "tokens"
  ],
  "properties": {
    "version": {
      "const": "proofnet-canonical-key-0.2"
    },
    "canonicalization": {
      "const": "proofnet-equivalent-intrinsic-v1"
    },
    "tokens": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100000,
      "items": {
        "type": "string",
        "maxLength": 1000000
      }
    }
  }
}
