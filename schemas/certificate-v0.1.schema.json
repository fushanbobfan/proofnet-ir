{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fushanbobfan/proofnet-ir/schemas/certificate-v0.1.schema.json",
  "title": "ProofNet-IR cut-free unit-free MLL certificate v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "formulas", "links", "conclusions"],
  "properties": {
    "version": { "const": "0.1" },
    "formulas": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/formula" }
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }
    },
    "conclusions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/vertex" }
    }
  },
  "$defs": {
    "vertex": { "type": "integer", "minimum": 0 },
    "formula": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "positive"],
          "properties": {
            "kind": { "const": "atom" },
            "name": { "type": "string", "minLength": 1 },
            "positive": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "left", "right"],
          "properties": {
            "kind": { "enum": ["tensor", "par"] },
            "left": { "$ref": "#/$defs/formula" },
            "right": { "$ref": "#/$defs/formula" }
          }
        }
      ]
    },
    "link": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "left", "right"],
          "properties": {
            "kind": { "const": "axiom" },
            "left": { "$ref": "#/$defs/vertex" },
            "right": { "$ref": "#/$defs/vertex" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "left", "right", "conclusion"],
          "properties": {
            "kind": { "enum": ["tensor", "par"] },
            "left": { "$ref": "#/$defs/vertex" },
            "right": { "$ref": "#/$defs/vertex" },
            "conclusion": { "$ref": "#/$defs/vertex" }
          }
        }
      ]
    }
  }
}
